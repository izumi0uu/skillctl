{
  "name": "skillctl-workspace",
  "private": true,
  "version": "0.2.2",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "version:set": "node scripts/release-version.mjs",
    "release:tag": "node scripts/release-tag.mjs",
    "release:check": "pnpm typecheck && pnpm test && pnpm health-suite",
    "release:mac": "pnpm --filter @skillctl/core build && pnpm --filter skillctl-electron-shell package:mac",
    "cli": "pnpm --filter skillctl-cli exec tsx src/index.ts",
    "health-suite": "pnpm --filter skillctl-cli exec tsx src/health-suite.ts",
    "ci:health": "pnpm typecheck && pnpm test && pnpm health-suite",
    "bootstrap-upstream": "pnpm --filter skillctl-cli exec tsx src/index.ts bootstrap-upstream"
  }
}
