{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.idah.dev/schemas/plan-bundle-v1.schema.json",
  "title": "Plan Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "bundle_id",
    "revision",
    "mode",
    "status",
    "title",
    "goal",
    "context",
    "facts",
    "scope",
    "constraints",
    "requirements",
    "acceptance_criteria",
    "design",
    "decision_record",
    "steps",
    "verification",
    "risks",
    "open_decisions"
  ],
  "properties": {
    "schema": {
      "const": "plan-bundle/v1"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "enum": [
        "plan",
        "ralplan"
      ]
    },
    "status": {
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "base_revision",
        "generated_at"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "base_revision": {
          "type": [
            "string",
            "null"
          ]
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text",
          "evidence"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in",
        "out"
      ],
      "properties": {
        "in": {
          "$ref": "#/$defs/stringArray"
        },
        "out": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "constraints": {
      "$ref": "#/$defs/stringArray"
    },
    "artifacts": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/artifactContract"
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REQ-[0-9]{3}$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "enum": [
              "must",
              "should",
              "could"
            ]
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "requirements",
          "proof"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-[0-9]{3}$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "requirements": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^REQ-[0-9]{3}$"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "proof": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "design": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary",
            "boundaries",
            "contracts",
            "compatibility",
            "rollout",
            "rollback",
            "observability"
          ],
          "properties": {
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "boundaries": {
              "$ref": "#/$defs/stringArray"
            },
            "contracts": {
              "$ref": "#/$defs/stringArray"
            },
            "compatibility": {
              "$ref": "#/$defs/stringArray"
            },
            "rollout": {
              "$ref": "#/$defs/stringArray"
            },
            "rollback": {
              "$ref": "#/$defs/stringArray"
            },
            "observability": {
              "$ref": "#/$defs/stringArray"
            }
          }
        }
      ]
    },
    "decision_record": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "principles",
            "drivers",
            "options",
            "chosen_option",
            "consequences"
          ],
          "properties": {
            "principles": {
              "$ref": "#/$defs/stringArray"
            },
            "drivers": {
              "$ref": "#/$defs/stringArray"
            },
            "options": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "summary",
                  "benefits",
                  "costs",
                  "viable"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "summary": {
                    "type": "string",
                    "minLength": 1
                  },
                  "benefits": {
                    "$ref": "#/$defs/stringArray"
                  },
                  "costs": {
                    "$ref": "#/$defs/stringArray"
                  },
                  "viable": {
                    "type": "boolean"
                  },
                  "invalidation_reason": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "chosen_option": {
              "type": "string",
              "minLength": 1
            },
            "consequences": {
              "$ref": "#/$defs/stringArray"
            },
            "premortem": {
              "$ref": "#/$defs/stringArray"
            }
          }
        }
      ]
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "depends_on",
          "files",
          "requirements",
          "verification"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^STEP-[0-9]{3}$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^STEP-[0-9]{3}$"
            },
            "uniqueItems": true
          },
          "files": {
            "$ref": "#/$defs/stringArray"
          },
          "requirements": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^REQ-[0-9]{3}$"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "verification": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^VER-[0-9]{3}$"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "level",
          "procedure",
          "covers"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^VER-[0-9]{3}$"
          },
          "level": {
            "enum": [
              "unit",
              "integration",
              "e2e",
              "static",
              "observability",
              "manual"
            ]
          },
          "procedure": {
            "type": "string",
            "minLength": 1
          },
          "covers": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^AC-[0-9]{3}$"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "risk",
          "trigger",
          "mitigation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^RISK-[0-9]{3}$"
          },
          "risk": {
            "type": "string",
            "minLength": 1
          },
          "trigger": {
            "type": "string",
            "minLength": 1
          },
          "mitigation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "open_decisions": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifactContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "schema",
        "schema_ref",
        "schema_digest",
        "contract_id",
        "revision",
        "path",
        "digest",
        "gates"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ART-[0-9]{3}$"
        },
        "kind": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
        },
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "schema_ref": {
          "$ref": "#/$defs/schemaRef"
        },
        "schema_digest": {
          "$ref": "#/$defs/digest"
        },
        "contract_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "path": {
          "$ref": "#/$defs/repoRelativePath"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        },
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactGate"
          }
        }
      }
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "schemaRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "skill_id",
            "path"
          ],
          "properties": {
            "kind": {
              "const": "skill"
            },
            "skill_id": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
            },
            "path": {
              "$ref": "#/$defs/repoRelativePath"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "path"
          ],
          "properties": {
            "kind": {
              "const": "repository"
            },
            "path": {
              "$ref": "#/$defs/repoRelativePath"
            }
          }
        }
      ]
    },
    "artifactGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "metric",
        "operator",
        "threshold",
        "covers_acceptance",
        "covers_verification",
        "rationale"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9-]{1,63}$"
        },
        "metric": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
        },
        "operator": {
          "enum": [
            "gte",
            "lte",
            "eq"
          ]
        },
        "threshold": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "boolean"
            }
          ]
        },
        "covers_acceptance": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^AC-[0-9]{3}$"
          }
        },
        "covers_verification": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^VER-[0-9]{3}$"
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ready"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "open_decisions": {
            "maxItems": 0
          },
          "requirements": {
            "minItems": 1
          },
          "acceptance_criteria": {
            "minItems": 1
          },
          "steps": {
            "minItems": 1
          },
          "verification": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode": {
            "const": "ralplan"
          }
        },
        "required": [
          "mode"
        ]
      },
      "then": {
        "properties": {
          "design": {
            "type": "object"
          },
          "decision_record": {
            "type": "object",
            "required": [
              "premortem"
            ],
            "properties": {
              "premortem": {
                "minItems": 3
              }
            }
          }
        }
      }
    }
  ]
}
