{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.idah.dev/schemas/visual-baseline-v1.schema.json",
  "title": "Visual Baseline v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "baseline_id",
    "revision",
    "status",
    "title",
    "source",
    "approved_at",
    "approved_by",
    "cases"
  ],
  "properties": {
    "schema": {
      "const": "visual-baseline/v1"
    },
    "baseline_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": [
        "draft",
        "approved"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "source_url",
        "permission_note"
      ],
      "properties": {
        "kind": {
          "enum": [
            "generated",
            "static",
            "live-url"
          ]
        },
        "source_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "permission_note": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "live-url"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "source_url": {
                "type": "string",
                "format": "uri",
                "minLength": 1
              },
              "permission_note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "approved_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "approved_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "cases": {
      "type": "object",
      "propertyNames": {
        "pattern": "^VIS-[0-9]{3}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/visualCase"
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "acceptanceIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^AC-[0-9]{3}$"
      }
    },
    "verificationIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^VER-[0-9]{3}$"
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "width",
        "height"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "device_scale_factor"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "device_scale_factor": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "version",
        "font_policy"
      ],
      "properties": {
        "os": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "font_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "x": {
          "type": "number",
          "minimum": 0
        },
        "y": {
          "type": "number",
          "minimum": 0
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "procedure_id",
        "command",
        "mode",
        "clip"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "procedure_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "enum": [
            "viewport",
            "full-page",
            "clip"
          ]
        },
        "clip": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/clip"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "clip"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "clip": {
                "$ref": "#/$defs/clip"
              }
            }
          },
          "else": {
            "properties": {
              "clip": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "state",
        "viewport",
        "browser",
        "platform",
        "color_scheme",
        "locale",
        "timezone",
        "auth_fixture",
        "data_fixture",
        "readiness_signal",
        "motion_policy",
        "network_policy",
        "capture"
      ],
      "properties": {
        "route": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "viewport": {
          "$ref": "#/$defs/viewport"
        },
        "browser": {
          "$ref": "#/$defs/browser"
        },
        "platform": {
          "$ref": "#/$defs/platform"
        },
        "color_scheme": {
          "enum": [
            "light",
            "dark",
            "system"
          ]
        },
        "locale": {
          "type": "string",
          "minLength": 1
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "auth_fixture": {
          "type": [
            "string",
            "null"
          ]
        },
        "data_fixture": {
          "type": "string",
          "minLength": 1
        },
        "readiness_signal": {
          "type": "string",
          "minLength": 1
        },
        "motion_policy": {
          "enum": [
            "disabled",
            "reduced-motion",
            "natural-settled"
          ]
        },
        "network_policy": {
          "enum": [
            "live",
            "mocked",
            "offline"
          ]
        },
        "capture": {
          "$ref": "#/$defs/capture"
        }
      }
    },
    "visualCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference",
        "environment",
        "interactions",
        "exclusions",
        "threshold",
        "threshold_rationale",
        "covers_acceptance",
        "covers_verification"
      ],
      "properties": {
        "reference": {
          "$ref": "#/$defs/artifact"
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "interactions": {
          "$ref": "#/$defs/stringArray"
        },
        "exclusions": {
          "$ref": "#/$defs/stringArray"
        },
        "threshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "threshold_rationale": {
          "type": "string",
          "minLength": 1
        },
        "covers_acceptance": {
          "$ref": "#/$defs/acceptanceIds"
        },
        "covers_verification": {
          "$ref": "#/$defs/verificationIds"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "approved"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "approved_at": {
            "type": "string",
            "format": "date-time"
          },
          "approved_by": {
            "type": "string",
            "minLength": 1
          },
          "cases": {
            "minProperties": 1
          }
        }
      }
    }
  ]
}
