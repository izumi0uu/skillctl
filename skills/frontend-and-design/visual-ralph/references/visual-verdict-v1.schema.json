{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.idah.dev/schemas/visual-verdict-v1.schema.json",
  "title": "Visual Verdict v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "bundle_id",
    "contract_revision",
    "bundle_digest",
    "baseline_id",
    "baseline_revision",
    "baseline_digest",
    "case_id",
    "reference",
    "candidate",
    "environment",
    "capture",
    "threshold",
    "score",
    "threshold_met",
    "status",
    "category_match",
    "dimensions",
    "differences",
    "suggestions",
    "pixel_diff",
    "evaluator",
    "observed_at"
  ],
  "properties": {
    "schema": {
      "const": "visual-verdict/v1"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "contract_revision": {
      "type": "integer",
      "minimum": 1
    },
    "bundle_digest": {
      "$ref": "#/$defs/digest"
    },
    "baseline_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "baseline_revision": {
      "type": "integer",
      "minimum": 1
    },
    "baseline_digest": {
      "$ref": "#/$defs/digest"
    },
    "case_id": {
      "type": "string",
      "pattern": "^VIS-[0-9]{3}$"
    },
    "reference": {
      "$ref": "#/$defs/artifact"
    },
    "candidate": {
      "$ref": "#/$defs/artifact"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "capture": {
      "$ref": "#/$defs/captureProvenance"
    },
    "threshold": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "score": {
      "$ref": "#/$defs/score"
    },
    "threshold_met": {
      "type": "boolean",
      "description": "Derived claim: the adapter must recompute score >= threshold and reject any mismatch."
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "inconclusive"
      ]
    },
    "category_match": {
      "type": "boolean"
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layout",
        "typography",
        "color",
        "spacing",
        "components",
        "content"
      ],
      "properties": {
        "layout": {
          "$ref": "#/$defs/score"
        },
        "typography": {
          "$ref": "#/$defs/score"
        },
        "color": {
          "$ref": "#/$defs/score"
        },
        "spacing": {
          "$ref": "#/$defs/score"
        },
        "components": {
          "$ref": "#/$defs/score"
        },
        "content": {
          "$ref": "#/$defs/score"
        }
      }
    },
    "differences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "region",
          "observation",
          "expected",
          "actual"
        ],
        "properties": {
          "severity": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "region": {
            "type": "string",
            "minLength": 1
          },
          "observation": {
            "type": "string",
            "minLength": 1
          },
          "expected": {
            "type": "string",
            "minLength": 1
          },
          "actual": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "suggestions": {
      "$ref": "#/$defs/stringArray"
    },
    "pixel_diff": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "mismatch_ratio"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "$ref": "#/$defs/digest"
            },
            "mismatch_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      ]
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "identifier",
        "independent"
      ],
      "properties": {
        "kind": {
          "enum": [
            "vision-agent",
            "human",
            "visual-tool"
          ]
        },
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "independent": {
          "type": "boolean"
        }
      }
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "width",
        "height"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/digest"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "device_scale_factor"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "device_scale_factor": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "version",
        "font_policy"
      ],
      "properties": {
        "os": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "font_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "x": {
          "type": "number",
          "minimum": 0
        },
        "y": {
          "type": "number",
          "minimum": 0
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "captureConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "procedure_id",
        "command",
        "mode",
        "clip"
      ],
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "procedure_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "enum": [
            "viewport",
            "full-page",
            "clip"
          ]
        },
        "clip": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/clip"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "clip"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "clip": {
                "$ref": "#/$defs/clip"
              }
            }
          },
          "else": {
            "properties": {
              "clip": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "state",
        "viewport",
        "browser",
        "platform",
        "color_scheme",
        "locale",
        "timezone",
        "auth_fixture",
        "data_fixture",
        "readiness_signal",
        "motion_policy",
        "network_policy",
        "capture"
      ],
      "properties": {
        "route": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "viewport": {
          "$ref": "#/$defs/viewport"
        },
        "browser": {
          "$ref": "#/$defs/browser"
        },
        "platform": {
          "$ref": "#/$defs/platform"
        },
        "color_scheme": {
          "enum": [
            "light",
            "dark",
            "system"
          ]
        },
        "locale": {
          "type": "string",
          "minLength": 1
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "auth_fixture": {
          "type": [
            "string",
            "null"
          ]
        },
        "data_fixture": {
          "type": "string",
          "minLength": 1
        },
        "readiness_signal": {
          "type": "string",
          "minLength": 1
        },
        "motion_policy": {
          "enum": [
            "disabled",
            "reduced-motion",
            "natural-settled"
          ]
        },
        "network_policy": {
          "enum": [
            "live",
            "mocked",
            "offline"
          ]
        },
        "capture": {
          "$ref": "#/$defs/captureConfig"
        }
      }
    },
    "captureProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_fingerprint",
        "captured_at",
        "procedure_id",
        "command",
        "readiness_observed"
      ],
      "properties": {
        "workspace_fingerprint": {
          "$ref": "#/$defs/digest"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "procedure_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "readiness_observed": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "threshold_met": {
            "const": true
          },
          "category_match": {
            "const": true
          },
          "differences": {
            "not": {
              "contains": {
                "type": "object",
                "properties": {
                  "severity": {
                    "const": "high"
                  }
                },
                "required": [
                  "severity"
                ]
              }
            }
          }
        }
      }
    }
  ]
}
