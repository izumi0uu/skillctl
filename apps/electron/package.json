{
  "name": "skillctl-electron-shell",
  "version": "0.2.0",
  "private": true,
  "description": "skillctl — portable skills control plane (macOS desktop shell)",
  "author": "izumi0uu",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:mac": "electron-vite build && electron-builder --config electron-builder.config.mjs --mac",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "lint": "pnpm typecheck",
    "test": "vitest run"
  },
  "devDependencies": {
    "@skillctl/core": "workspace:*",
    "@electron/notarize": "^2.5.0",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^5.4.11",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "iconoir-react": "^7.11.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
