{
  "sourceRoots": [
    {
      "path": "./skills",
      "visibility": "public",
      "managedByDefault": true
    },
    {
      "path": "~/.claude/skills",
      "visibility": "public",
      "managedByDefault": false
    }
  ],
  "privateRoots": [
    "~/.agents/skills"
  ],
  "enabledAdapters": [
    "claude-code",
    "codex",
    "pi",
    "hermes",
    "opencode"
  ],
  "excludeSkills": [],
  "liveProbePolicy": "safe"
  ,
  "transport": {
    "mode": "skills-cli",
    "command": "npx",
    "args": ["--yes", "skills"],
    "embeddedRepoPath": "./vercel-skills"
  }
}
