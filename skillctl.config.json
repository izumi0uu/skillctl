{
  "sourceRoots": [
    {
      "path": "./skills",
      "visibility": "public",
      "managedByDefault": true
    }
  ],
  "privateRoots": [],
  "enabledAdapters": [
    "claude-code",
    "codex",
    "pi",
    "hermes",
    "opencode"
  ],
  "excludeSkills": [],
  "liveProbePolicy": "off",
  "transport": {
    "mode": "skills-cli",
    "command": "npx",
    "args": ["--yes", "skills"],
    "embeddedRepoPath": "./vercel-skills"
  }
}
